#!/bin/sh
# Copyright (c) 2014 Michael Moosbauer
#
# init.d/emstriggerd
#
### BEGIN INIT INFO
# Provides:       emstriggerd
# Required-Start: $network $remote_fs $syslog $named
# Required-Stop:
# Default-Start:  3 5
# Default-Stop:
# Description:    Starts EMS-trigger daemon
### END INIT INFO
. /etc/rc.status
PGMDIR="/home/programming/Heizung/ems-tools/ems-triggerd"
LOGFILE="/var/log/ems/emstriggerd.log"

case "$1" in
    start)
        echo -n "Starting EMS-trigger daemon"
	startproc $PGMDIR/ems-triggerd.php >> $LOGFILE 2>&1
	rc_status -v
	;;
    stop)

        echo -n "Stopping EMS-trigger daemon"
	killproc $PGMDIR/ems-triggerd.php
	rc_status -v
	;;
    status)

        echo -n "EMS-trigger daemon is"
	checkproc $PGMDIR/ems-triggerd.php
	rc_status -v
	;;
    reload|restart)
        $0 stop && sleep 3 && $0 start
	;;
    *)
	echo "Usage: $0 {start|stop|status|reload|restart}"
	exit 1
esac

